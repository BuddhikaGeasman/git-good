---
import Layout from '../layouts/Layout.astro';
import Nav from '../layouts/Nav.astro';

const changelogs = await Astro.glob('./changelog/*.mdx');

const sortedChangelogs = changelogs
  .filter((log) => log.frontmatter?.date)
  .sort((a, b) => {
    const dateA = new Date(a.frontmatter.date);
    const dateB = new Date(b.frontmatter.date);
    return dateB.getTime() - dateA.getTime();
  });
---

<Layout title='git good' description='Development changelog'>
  <header>
    <h1>git good</h1>
    <p class='subtitle'>Development changelog</p>
  </header>

  <Nav />

  <main class='changelog'>
    {
      sortedChangelogs.map((log) => (
        <div class='entry'>
          <h2>{log.frontmatter.title}</h2>
          <div class='entry-content'>
            <log.Content />
          </div>
        </div>
      ))
    }
  </main>
</Layout>

<style>
  .changelog .entry {
    margin-bottom: 1.5rem;
  }

  /* Remove extra spacing from changelog content */
  .entry-content :global(h3),
  .entry-content :global(h4) {
    margin-top: 1rem;
    margin-bottom: 0.5rem;
  }

  .entry-content :global(h2) {
    margin-top: 0.5rem;
  }

  .entry-content :global(ul),
  .entry-content :global(ol) {
    margin: 0.5rem 0;
  }

  .entry-content :global(p) {
    margin-bottom: 0.5rem;
  }
</style>
